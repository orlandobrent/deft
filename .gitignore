# Distribution
dist/

# Backup files
backup/

# Node modules (if using markdown linting)
node_modules/

# OS files
.DS_Store
Thumbs.db

# Editor files
.vscode/
.idea/
*.swp
*.swo
*~

# Temporary files
*.tmp
*.bak

# Transient agent scratch directory (PR #401 trim arc convention -- see #642)
temp/

# User-specific files (users should copy from templates)
core/user.md

# Go build artifacts
*.exe

# Python toolchain
.venv/
__pycache__/
*.pyc
*.pyo
.coverage
htmlcov/
.pytest_cache/
*.egg-info/

# Secrets (project-specific)
secrets/

# vContext state
vcontext/

# Generated Deft exports
.deft/

# Pre-cutover backups written by `task migrate:vbrief` (#497, #506 D7).
# Operators who want these versioned can delete these lines or override per-file.
*.premigrate.*
vbrief/*.premigrate.*

# Migration backups (created by `task migrate:vbrief`) -- do NOT commit.
# Post-commit, pre-migration state is recoverable via git history; see
# deft/main.md § Safety flags for the post-commit recovery path.
*.premigrate.md
*.premigrate.vbrief.json

# Local triage / refinement issue cache (#845 Story 1). Sidecar mirror of
# `gh issue list` populated by `task triage:cache`; never versioned. See
# scripts/triage_cache.py for the layout (.deft-cache/issues/<owner>-<repo>/).
.deft-cache/
