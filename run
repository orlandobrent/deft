For more information: https://github.com/deftai/directive
""")

def ask_input(prompt_text: str, default: str = "") -> str:
    """Read user input with optional default
    
    Args:
        prompt_text: The prompt to display
        default: Default value if user presses Enter
    
    Returns:
        User input or default value
    """
    try:
        # Priority: prompt_toolkit (best editing) > rich > basic input
        if HAS_PROMPT_TOOLKIT:
            from prompt_toolkit import prompt as pt_prompt
            from prompt_toolkit.formatted_text import HTML
            # Add colored prefix if rich is also available
            if HAS_RICH:
                display_prompt = HTML(f'<ansibrightcyan>?</ansibrightcyan> {prompt_text}: ')
            else:
                display_prompt = prompt_text + ": "
            
            value = pt_prompt(display_prompt, default=default)
            return value if value else default
        elif HAS_RICH:
            # Add colored question mark prefix
            formatted_prompt = f"[cyan]?[/cyan] {prompt_text}"
            value = Prompt.ask(formatted_prompt, default=default if default else None)
            return value if value else default
        else:
            # Fall back to basic input() with readline support (if available on Unix)
            if default:
                value = input(f"{prompt_text} [{default}]: ")
            else:
                value = input(f"{prompt_text}: ")
            return value if value else default
    except EOFError:
        return default

def ask_choice(prompt_text: str, choices: List[str], default: str = None) -> str:
    """Read user choice from list
    
    Args:
        prompt_text: The prompt to display
        choices: List of valid choices
        default: Default choice
    
    Returns:
        User's choice
    """
    try:
        if HAS_RICH:
            # Add colored question mark prefix
            formatted_prompt = f"[cyan]?[/cyan] {prompt_text}"
            return Prompt.ask(formatted_prompt, choices=choices, default=default)
        else:
            # Fallback: show numbered list
            print(f"\n{prompt_text}")
            for i, choice in enumerate(choices, 1):
                print(f"  {i}. {choice}")
            while True:
                ans = input("Enter number: ")
                try:
                    idx = int(ans) - 1
                    if 0 <= idx < len(choices):
                        return choices[idx]
                except ValueError:
                    pass
                print("Invalid choice, try again.")
    except EOFError:
        return default if default else choices[0]

def ask_confirm(prompt_text: str, default: bool = False) -> bool:
    """Read yes/no confirmation
    
    Args:
        prompt_text: The prompt to display
        default: Default value
    
    Returns:
        True if user confirms, False otherwise
    """
    try:
        # Priority: prompt_toolkit > rich > basic input
        if HAS_PROMPT_TOOLKIT:
            from prompt_toolkit import prompt as pt_prompt
            from prompt_toolkit.formatted_text import HTML
            # Add colored prefix if rich is also available
            suffix = " (Y/n): " if default else " (y/N): "
            if HAS_RICH:
                display_prompt = HTML(f'<ansibrightcyan>?</ansibrightcyan> {prompt_text}{suffix}')
            else:
                display_prompt = prompt_text + suffix
            
            response = pt_prompt(display_prompt, default="")
            if not response:
                return default
            return response.strip().lower() in ('y', 'yes')
        elif HAS_RICH:
            # Add colored question mark prefix
            formatted_prompt = f"[cyan]?[/cyan] {prompt_text}"
            return Confirm.ask(formatted_prompt, default=default)
        else:
            suffix = " (Y/n) " if default else " (y/N) "
            response = input(f"{prompt_text}{suffix}")
            if not response:
                return default
            return response.strip().lower() in ('y', 'yes')
    except EOFError:
        return default

# Legacy aliases
read_input = ask_input
read_yn = ask_confirm

# --- Upgrade gate (#410) ---------------------------------------------------
#
# `deft/run` is the one deterministic entry point directive controls that runs
# in the consumer project's working directory.  After a framework update, we
# compare a `.deft-version` marker to VERSION and warn on drift.  Non-fatal by
# design: interactive sessions get a prompt ("continue anyway? [y/N]"),
# non-interactive sessions warn once and continue so CI/cloud runs are not
# blocked.  See issue #410 for scope boundaries (CLI users only; the
# agent-interpreted path is gated by the sync/setup skills).

def _version_marker_paths(project_root: Path) -> List[Path]:
    """Return candidate `.deft-version` paths, preferred location first."""
    return [project_root / "vbrief" / ".deft-version", project_root / ".deft-version"]


def _read_version_marker(project_root: Path) -> Optional[str]:
    """Return the recorded framework version, or None if no marker exists.

    Iterates candidate paths in preference order; an OSError on the preferred
    path (e.g. unreadable due to permissions) falls through to the fallback
    so version-drift detection is not silently suppressed (#410).
    """
    for candidate in _version_marker_paths(project_root):
        if candidate.is_file():
            try:
                return candidate.read_text(encoding="utf-8").strip()
            except OSError:
                continue
    return None


def _write_version_marker(vbrief_root: Path) -> None:
    """Write VERSION into `vbrief/.deft-version` (best-effort, never raises)."""
    try:
        vbrief_root.mkdir(parents=True, exist_ok=True)
        (vbrief_root / ".deft-version").write_text(VERSION + "\n", encoding="utf-8")
    except OSError:
        pass


def _detect_pre_cutover_legacy(project_root: Path) -> List[str]:
    """Return legacy artifact filenames missing the deprecation redirect sentinel."""
    legacy: List[str] = []
    for fname in ("SPECIFICATION.md", "PROJECT.md"):
        candidate = project_root / fname
        if not candidate.is_file():
            continue
        try:
            content = candidate.read_text(encoding="utf-8", errors="replace")
        except OSError:
            continue
        if DEPRECATED_REDIRECT_SENTINEL not in content:
            legacy.append(fname)
    return legacy


def _running_inside_deft_repo(project_root: Path) -> bool:
    """Heuristic: True when `run` is invoked from inside the deft repo itself.

    Consumer projects embed deft as `./deft/`; the deft source repo has
    `main.md` at its root and no `./deft/` subdirectory.  Skipping the gate
    here avoids nagging deft maintainers on every `run` invocation.
    """
    return (project_root / "main.md").is_file() and not (project_root / "deft").is_dir()


# Commands for which the gate is silent -- they never touch project state.
_UPGRADE_GATE_SKIP_COMMANDS = frozenset({
    "help", "--help", "-h", "-help",
    "version", "--version", "-v",
    "upgrade",  # the upgrade command itself must run so users can resolve the gate
    # #768: cmd_gate IS the upgrade gate -- if the agent invokes it from the
    # AGENTS.md preamble, it must not recursively re-trigger the legacy CLI
    # gate prompt. cmd_agents_refresh likewise must run unconditionally so the
    # universal preamble's recovery path can call it.
    "gate",
    "agents:refresh",
})


def _emit_event_safe(name: str, payload: dict) -> None:
    """Lazy-import emit() and swallow all failures.

    Keeps the events surface optional from `run`'s perspective:
    `scripts/_event_detect.py` is imported only when actually emitting, and
    any ImportError / OSError / EventEmissionError is silently dropped so
    the CLI never breaks because of an event-surface bug. Per #635.
    """
    # Bare ``except Exception`` swallows every failure mode the events
    # surface could surface (ImportError when the helper file is missing,
    # OSError when DEFT_EVENT_LOG points at a read-only path,
    # EventEmissionError when the registry rejects the name) without
    # leaking any of them up to the CLI.
    try:
        scripts_dir = get_script_dir() / "scripts"
        if str(scripts_dir) not in sys.path:
            sys.path.insert(0, str(scripts_dir))
        # #635: detection-bound emit helper (distinct from behavioral sibling).
        from _event_detect import emit  # type: ignore[import-not-found]
        emit(name, payload)
    except Exception:  # noqa: BLE001 -- non-fatal; events MUST NOT break CLI
        return


def _check_upgrade_gate(command: str) -> bool:
    """Warn (and prompt when interactive) on framework/project version drift.

    Returns True if the caller should proceed, False only when the user
    explicitly declines in an interactive session.  Never fatal otherwise --
    in non-interactive environments (CI, cloud agents) we warn and continue.
    """
    if command in _UPGRADE_GATE_SKIP_COMMANDS:
        return True

    project_root = Path.cwd()
    if _running_inside_deft_repo(project_root):
        return True

    recorded = _read_version_marker(project_root)
    vbrief_dir = project_root / "vbrief"

    if recorded is not None:
        if recorded == VERSION:
            return True
        # #635: emit version:drift before warning so consumers can react
        # uniformly. Marker path resolution mirrors _read_version_marker's
        # precedence rule (vbrief/.deft-version > .deft-version).
        marker_path = next(
            (str(p) for p in _version_marker_paths(project_root) if p.is_file()),
            "",
        )
        _emit_event_safe(
            "version:drift",
            {
                "project_root": str(project_root.resolve()),
                "recorded_version": recorded,
                "current_version": VERSION,
                "marker_path": marker_path,
            },
        )
        warn(
            f"Deft has been updated from {recorded} to {VERSION}. "
            "Run `deft/run upgrade` or `task migrate:vbrief` to update your project files."
        )
    else:
        legacy = _detect_pre_cutover_legacy(project_root)
        if not legacy:
            # No marker, no legacy artifacts -- either a fully-migrated project
            # whose marker was never written, or not a deft-managed project.
            # Either way there is nothing actionable to gate on.
            return True
        # #635: emit pre-cutover:detected before warning so consumers can
        # react uniformly (skill, task, CI runner). Existing CLI warning
        # text is preserved verbatim below.
        _emit_event_safe(
            "pre-cutover:detected",
            {
                "project_root": str(project_root.resolve()),
                "legacy_files": list(legacy),
            },
        )
        # Legacy artifacts present (with or without vbrief/) -- this covers
        # both the canonical v0.19 consumer layout (no vbrief/ yet) and a
        # partially-migrated project that still has legacy copies.
        warn(
            "Pre-v0.20 document model detected ("
            + ", ".join(legacy)
            + "). Run `task migrate:vbrief` to upgrade."
        )

    # #635: AGENTS.md staleness is checked alongside version drift /
    # pre-cutover so the upgrade gate emits a single coherent set of events
    # for consumers that subscribe via DEFT_EVENT_LOG. No new CLI output --
    # the existing QUICK-START.md prose flow is the user-visible surface;
    # the event is purely structural.
    try:
        scripts_dir = get_script_dir() / "scripts"
        if str(scripts_dir) not in sys.path:
            sys.path.insert(0, str(scripts_dir))
        from _event_detect import detect_agents_md_stale  # type: ignore[import-not-found]
        stale_payload = detect_agents_md_stale(project_root)
        if stale_payload is not None:
            _emit_event_safe("agents-md:stale", stale_payload)
    except Exception:
        # Detection MUST NOT break the gate.
        pass

    # Non-interactive: warn and continue, never fatal.
    if not sys.stdin.isatty():
        return True

    try:
        if read_yn("Continue anyway?", default=False):
            return True
    except (EOFError, KeyboardInterrupt):
        return True

    warn("Exiting -- upgrade your project and re-run.")
    return False


# --- Universal upgrade gate (#768) -----------------------------------------
#
# `cmd_gate` is a read-only state-vector probe that any AGENTS.md / SKILL.md
# preamble (`<!-- DEFT-PREAMBLE-V1 -->`) can call before doing anything else.
# Output is one line on stdout in two shapes:
#
#   OK v<current>
#   NEEDS-UPGRADE recorded=<recorded|unknown> current=<current> precutover=<csv|empty> agents-md=<current|stale|missing|absent>
#
# `--json` emits the same axes as a single JSON object on stdout. Exit code is
# 0 for OK and 1 for NEEDS-UPGRADE. The probe never writes any markers, never
# triggers any migration, and never commits anything: the agent reads the
# state vector, then reads `deft/UPGRADING.md` for the matching section.
#
# `cmd_agents_refresh` is the Python reference implementation of the
# AGENTS.md contract surfaced by `templates/agents-entry.md`. It handles four
# states (`current`, `stale`, `missing`, `absent`) and exposes `--check` and
# `--dry-run` so the gate (and tests) can interrogate it without writing.
#
# Both functions are intentionally side-effect-free apart from `print()` so
# the test harness can capture stdout via the `run_command` fixture.

_AGENTS_MANAGED_OPEN = "<!-- deft:managed-section v1 -->"
_AGENTS_MANAGED_CLOSE = "<!-- /deft:managed-section -->"


def _agents_template_path() -> Path:
    """Return the absolute path to the canonical AGENTS.md template."""
    return get_script_dir() / "templates" / "agents-entry.md"


def _read_agents_template() -> Optional[str]:
    """Return the AGENTS.md template text, or None when not readable.

    The Go installer embeds the same file via `//go:embed` in
    `templates/embed.go`; the Python rail reads it from disk at runtime so
    `cmd_agents_refresh` works against the live framework checkout.
    """
    candidate = _agents_template_path()
    if not candidate.is_file():
        return None
    try:
        return candidate.read_text(encoding="utf-8")
    except OSError:
        return None


def _render_managed_section(template_text: str) -> Optional[str]:
    """Extract the `<!-- deft:managed-section v1 -->` block from the template.

    Returns the byte sequence (newlines normalised to ``\n``) bracketed by
    the open/close markers, INCLUSIVE. Returns None when either marker is
    missing -- the contract test asserts the template carries both.

    Placeholder substitution is intentionally a no-op in the v1 reference
    implementation: the documented tokens (`{{UPSTREAM_SHA}}`, etc.) are
    inherited from the webinstaller pin-marker contract and rendered there.
    Leaving them as literal `{{TOKEN}}` text keeps `--check` byte-stable
    when the framework is checked out without git metadata, and is the
    documented behaviour in `templates/agents-entry.placeholders.md`.
    """
    normalised = template_text.replace("\r\n", "\n")
    open_idx = normalised.find(_AGENTS_MANAGED_OPEN)
    close_idx = normalised.find(_AGENTS_MANAGED_CLOSE)
    if open_idx < 0 or close_idx < 0 or close_idx <= open_idx:
        return None
    end = close_idx + len(_AGENTS_MANAGED_CLOSE)
    return normalised[open_idx:end]


def _extract_managed_section(text: str) -> Optional[str]:
    """Pull the managed-section block out of the consumer's AGENTS.md text.

    Returns the bracketed block (normalised to LF) or None if either
    marker is absent.
    """
    normalised = text.replace("\r\n", "\n")
    open_idx = normalised.find(_AGENTS_MANAGED_OPEN)
    close_idx = normalised.find(_AGENTS_MANAGED_CLOSE)
    if open_idx < 0 or close_idx < 0 or close_idx <= open_idx:
        return None
    end = close_idx + len(_AGENTS_MANAGED_CLOSE)
    return normalised[open_idx:end]


def _classify_agents_md(project_root: Path) -> str:
    """Return one of: `current`, `stale`, `missing`, `absent`.

    - ``absent``  -> ./AGENTS.md does not exist
    - ``missing`` -> ./AGENTS.md exists but has no managed-section markers
    - ``stale``   -> markers present but bracketed bytes != current template render
    - ``current`` -> bracketed bytes byte-identical to current template render

    A missing or unreadable template falls through to ``current`` so the
    gate never fires solely because the framework checkout itself is
    incomplete.
    """
    agents_md = project_root / "AGENTS.md"
    if not agents_md.is_file():
        return "absent"
    try:
        existing = agents_md.read_text(encoding="utf-8", errors="replace")
    except OSError:
        return "absent"
    extracted = _extract_managed_section(existing)
    if extracted is None:
        return "missing"
    template_text = _read_agents_template()
    if template_text is None:
        # Framework checkout incomplete -- err on the side of "current" so
        # the universal gate doesn't refuse to start.
        return "current"
    rendered = _render_managed_section(template_text)
    if rendered is None:
        return "current"
    return "current" if extracted == rendered else "stale"


def _build_gate_state(project_root: Path) -> dict:
    """Compute the full state vector consumed by both cmd_gate and the JSON
    surface. Pure -- no I/O outside ``project_root`` and the framework
    template. Reuses ``_read_version_marker`` (#410), ``_detect_pre_cutover_legacy``
    (#410), ``_running_inside_deft_repo`` (#410), and the dynamic
    ``VERSION`` (#741) so the gate inherits every existing detection rule.
    """
    recorded = _read_version_marker(project_root)
    legacy = _detect_pre_cutover_legacy(project_root)
    agents_md = _classify_agents_md(project_root)
    inside_deft = _running_inside_deft_repo(project_root)
    return {
        "current": VERSION,
        "recorded": recorded,
        "precutover": list(legacy),
        "agents-md": agents_md,
        "inside_deft_repo": inside_deft,
    }


def _gate_state_is_ok(state: dict) -> bool:
    """Return True iff the state vector indicates no upgrade work needed."""
    if state.get("inside_deft_repo"):
        # Maintainer working inside the deft repo itself -- the gate stays
        # green so framework dev is never blocked by the consumer-facing
        # upgrade flow.
        return True
    recorded = state.get("recorded")
    current = state.get("current")
    precutover = state.get("precutover") or []
    agents_md = state.get("agents-md")
    if precutover:
        return False
    if recorded is not None and recorded != current:
        return False
    if agents_md == "stale":
        return False
    if agents_md == "missing":
        return False
    # All other states pass: a marker that matches `current`, or no marker
    # with no precutover artifacts and `agents-md=absent` (indistinguishable
    # from "not a deft project" -- mirrors `_check_upgrade_gate`'s
    # heuristic). Both branches converge here, so a single trailing
    # `return True` covers them.
    return True


def _format_gate_line(state: dict) -> str:
    """Render the one-line text surface consumed by the AGENTS.md preamble."""
    if _gate_state_is_ok(state):
        return f"OK v{state['current']}"
    recorded = state.get("recorded") or "unknown"
    precutover = ",".join(state.get("precutover") or [])
    agents_md = state.get("agents-md") or "absent"
    return (
        "NEEDS-UPGRADE "
        f"recorded={recorded} "
        f"current={state['current']} "
        f"precutover={precutover} "
        f"agents-md={agents_md}"
    )


def cmd_gate(args: List[str]):
    """Read-only universal upgrade gate (#768).

    Emits a single line (or a JSON object with ``--json``) describing the
    consumer project's deft state vector. Exit code is 0 when no upgrade
    work is needed, 1 otherwise. NEVER writes the marker, NEVER touches
    AGENTS.md, NEVER runs migration -- it is a probe.

    Output shapes::

        OK v<current>
        NEEDS-UPGRADE recorded=<recorded|unknown> current=<current> \
            precutover=<csv|empty> agents-md=<current|stale|missing|absent>

    The agent-readable preamble in `main.md`, `SKILL.md`, and the legacy
    redirect stubs (`skills/deft-setup/SKILL.md`, `skills/deft-build/SKILL.md`)
    runs this command before any other instruction; on a non-zero exit the
    agent reads `deft/UPGRADING.md` and follows the section whose
    "Applies when" clause matches the printed state vector.
    """
    json_mode = "--json" in args
    project_root = Path.cwd()
    state = _build_gate_state(project_root)
    if json_mode:
        payload = {
            "status": "ok" if _gate_state_is_ok(state) else "needs-upgrade",
            "current": state["current"],
            "recorded": state["recorded"],
            "precutover": state["precutover"],
            "agents-md": state["agents-md"],
            "inside_deft_repo": state["inside_deft_repo"],
        }
        print(json.dumps(payload, sort_keys=True))
    else:
        print(_format_gate_line(state))
    return 0 if _gate_state_is_ok(state) else 1


def _wrap_legacy_in_markers(existing: str, rendered: str) -> str:
    """Produce the once-per-project legacy-to-marker migration body.

    The consumer's existing pre-marker AGENTS.md content (often a hand-rolled
    deft entry from a v0.19 install) is preserved verbatim ABOVE the new
    managed section -- so user notes outside the deft block survive the
    migration. The rendered managed-section block is appended (with a
    blank-line separator) so subsequent ``current``/`stale` refreshes can
    operate on the bracketed region in place.
    """
    body = existing.replace("\r\n", "\n").rstrip("\n")
    if body:
        return body + "\n\n" + rendered + "\n"
    return rendered + "\n"


def _agents_refresh_plan(project_root: Path) -> dict:
    """Compute the plan ``cmd_agents_refresh`` would apply (no I/O)."""
    template_text = _read_agents_template()
    if template_text is None:
        return {
            "state": "template-missing",
            "path": str(project_root / "AGENTS.md"),
            "rendered": None,
            "existing": None,
            "new_content": None,
        }
    rendered = _render_managed_section(template_text)
    if rendered is None:
        return {
            "state": "template-malformed",
            "path": str(project_root / "AGENTS.md"),
            "rendered": None,
            "existing": None,
            "new_content": None,
        }
    agents_md = project_root / "AGENTS.md"
    if not agents_md.is_file():
        return {
            "state": "absent",
            "path": str(agents_md),
            "rendered": rendered,
            "existing": None,
            "new_content": rendered + "\n",
        }
    try:
        existing = agents_md.read_text(encoding="utf-8", errors="replace")
    except OSError as exc:
        return {
            "state": "unreadable",
            "path": str(agents_md),
            "rendered": rendered,
            "existing": None,
            "new_content": None,
            "error": str(exc),
        }
    extracted = _extract_managed_section(existing)
    normalised = existing.replace("\r\n", "\n")
    if extracted is None:
        # Legacy file with no markers -- one-time migration: wrap the
        # existing content + render the managed-section beneath it.
        new_content = _wrap_legacy_in_markers(normalised, rendered)
        return {
            "state": "missing",
            "path": str(agents_md),
            "rendered": rendered,
            "existing": existing,
            "new_content": new_content,
        }
    if extracted == rendered:
        return {
            "state": "current",
            "path": str(agents_md),
            "rendered": rendered,
            "existing": existing,
            "new_content": existing,
        }
    # Stale: byte-replace the bracketed block in place.
    new_content = normalised.replace(extracted, rendered, 1)
    return {
        "state": "stale",
        "path": str(agents_md),
        "rendered": rendered,
        "existing": existing,
        "new_content": new_content,
    }


def cmd_agents_refresh(args: List[str]):
    """Python reference implementation of the AGENTS.md contract (#768).

    Modes:
        ``--check``   -> exit 0 iff the consumer's managed section is
                        byte-identical to the rendered template; non-zero
                        otherwise. Never writes.
        ``--dry-run`` -> print the planned change; never writes.
        (default)     -> apply the planned change idempotently, handling
                        the four states (`current`/`stale`/`missing`/`absent`).

    The bracketed region is the SOLE byte sequence the framework owns.
    Content above or below the markers is preserved verbatim, so consumer
    notes survive every refresh.
    """
    check = "--check" in args
    dry_run = "--dry-run" in args
    project_root = Path.cwd()
    plan = _agents_refresh_plan(project_root)
    state = plan["state"]

    if state == "template-missing":
        if check:
            return 1
        error(
            "AGENTS.md template not found at "
            f"{_agents_template_path()} -- skipping refresh."
        )
        return 1
    if state == "template-malformed":
        if check:
            return 1
        error(
            "AGENTS.md template is missing the deft:managed-section markers "
            "-- skipping refresh."
        )
        return 1
    if state == "unreadable":
        if check:
            return 1
        error(f"AGENTS.md exists but is unreadable: {plan.get('error', '')}")
        return 1

    if check:
        # `--check` only succeeds when the file already exists with the
        # exact rendered managed-section bytes. `absent` and `missing`
        # both need a write, so they fail the check.
        return 0 if state == "current" else 1

    if dry_run:
        print(f"AGENTS.md state: {state}")
        print(f"Path: {plan['path']}")
        if state == "current":
            print("Plan: no-op (managed section already current)")
            return 0
        if state == "absent":
            print("Plan: create AGENTS.md from rendered template")
        elif state == "missing":
            print(
                "Plan: wrap existing content above the new managed section "
                "(one-time legacy migration)"
            )
        elif state == "stale":
            print("Plan: byte-replace managed section with rendered template")
        return 0

    if state == "current":
        # Idempotent no-op; align with cmd_upgrade's quiet success path.
        info("AGENTS.md managed section already current.")
        return 0

    new_content = plan["new_content"]
    target = Path(plan["path"])
    try:
        target.parent.mkdir(parents=True, exist_ok=True)
        target.write_text(new_content, encoding="utf-8")
    except OSError as exc:
        error(f"Could not write AGENTS.md: {exc}")
        return 1

    if state == "absent":
        success(f"Created AGENTS.md from template at {target}.")
    elif state == "missing":
        success(
            "Wrapped existing AGENTS.md content above the new managed "
            "section (one-time legacy migration)."
        )
    elif state == "stale":
        success("Refreshed AGENTS.md managed section to current template.")
    return 0


def cmd_upgrade(args: List[str]):
    """Acknowledge the framework upgrade and write the `.deft-version` marker.

    This command only records the framework version so the upgrade gate stops
    warning.  It delegates the heavy lifting (SPECIFICATION.md / PROJECT.md
    migration, lifecycle folder creation) to `task migrate:vbrief`.

    #768: also calls ``cmd_agents_refresh`` so the AGENTS.md managed
    section is brought to the current rendered template alongside the
    marker write -- closes the stale-AGENTS.md adoption-blocker without
    requiring a separate manual step.
    """
    print_header(f"Deft CLI v{VERSION} - Upgrade")
    print()
    project_root = Path.cwd()
    recorded = _read_version_marker(project_root)
    if recorded == VERSION:
        success(f"Project already at {VERSION}. Nothing to do.")
        # Still refresh AGENTS.md in case the consumer's marker is current
        # but the template moved -- byte-stable when already at the latest.
        # Greptile P1: propagate the refresh return code so a failed AGENTS.md
        # write surfaces as a non-zero `deft/run upgrade` exit instead of
        # leaving the project partially upgraded with a silent success.
        return cmd_agents_refresh([])

    legacy = _detect_pre_cutover_legacy(project_root)
    if legacy:
        warn(
            "Pre-v0.20 document model detected ("
            + ", ".join(legacy)
            + "). Run `task migrate:vbrief` first -- it migrates legacy "
            "artifacts and creates the lifecycle folder structure. This "
            "command only records the framework version."
        )

    vbrief_dir = project_root / "vbrief"
    target_dir = vbrief_dir if vbrief_dir.is_dir() else project_root
    _write_version_marker(target_dir)

    if recorded is None:
        success(f"Recorded framework version {VERSION} in .deft-version.")
    else:
        success(f"Updated .deft-version from {recorded} to {VERSION}.")
    info(
        "If legacy SPECIFICATION.md or PROJECT.md content remains, run "
        "`task migrate:vbrief` to complete the upgrade."
    )
    # #768: bring AGENTS.md to the current template alongside the marker.
    # Greptile P1: propagate the refresh return code so a failed AGENTS.md
    # write surfaces as a non-zero `deft/run upgrade` exit instead of
    # leaving the project partially upgraded with a silent success.
    return cmd_agents_refresh([])


def cmd_bootstrap(args: List[str]):
    """Bootstrap command - set up user.md"""
    print_header(f"Deft CLI v{VERSION} - Bootstrap")
    print()
    info("This command creates user.md, which defines YOUR personal preferences:")
    info("  • Your name (how the AI should address you)")
    info("  • Primary programming languages")
    info("  • Default test coverage threshold")
    info("  • Development strategy")
    info("  • Custom rules and experimental guidelines")
    print()
    info("These preferences apply across all your projects and only need to be set once.")
    info("You can update them anytime by editing user.md or re-running bootstrap.")
    print()
    
    defaults = get_default_paths()
    
    # Resume support (issue #8)
    prog_file = _progress_path(resolve_path(defaults['user']))
    progress = {}
    if prog_file.exists():
        saved = _load_progress(prog_file)
        if saved:
            print_section("Previous Session Found")
            for k, v in saved.items():
                if not k.startswith('_'):
                    info(f"  {k}: {v}")
            print()
            if read_yn("Resume where you left off?", default=True):
                progress = saved
            else:
                _clear_progress(prog_file)
    
    if 'output_path' not in progress:
        print_section("Output Location")
    user_path_str = _resume_or_ask(progress, prog_file, 'output_path', 'Output',
                                    read_input, "Where to write USER.md", defaults['user'])
    user_file = resolve_path(user_path_str)
    
    # Check if file exists (skip when resuming — user already committed)
    if not progress.get('user_name'):
        if user_file.exists() and "--force" not in args:
            info(f"USER.md already exists at {user_file}")
            if not read_yn("Overwrite with new preferences?"):
                success("Keeping existing USER.md as-is.")
                print()
                # Still offer next steps even when keeping existing file
                print_section("Next Steps")
                if read_yn("Would you like to run 'run project' now?", default=True):
                    print()
                    return cmd_project([])
                else:
                    print()
                    info("You can run 'run project' later to configure your project")
                    return 0
    
    if 'user_name' not in progress:
        print()
        print_section("User Preferences Setup")
    
    # Gather user information
    user_name = _resume_or_ask(progress, prog_file, 'user_name', 'Name',
                                read_input, "Your name (how AI should address you)")
    if 'coverage' not in progress:
        while True:
            coverage = read_input("Default coverage threshold (default: 85%)", "85")
            if not coverage.strip():
                coverage = "85"
                break
            try:
                val = int(coverage.strip())
                if 1 <= val <= 100:
                    break
            except ValueError:
                pass
            print_error("Please enter a number between 1 and 100.")
        progress['coverage'] = coverage
        _save_progress(prog_file, progress)
    else:
        coverage = progress['coverage']
        info(f"  [resumed] Coverage: {coverage}")
    
    available_langs = get_available_languages()
    other_num = len(available_langs) + 1
    valid_lang_nums = set(str(i) for i in range(1, other_num + 1))
    if 'lang_selection' not in progress:
        print()
        print_section("Programming Languages")
        info("Select your primary programming languages (comma-separated):")
        for i, (stem, display) in enumerate(available_langs, 1):
            print(f"  {i}. {display}")
        print(f"  {other_num}. Other")
        while True:
            lang_selection = read_input("Selection (e.g., 1,3 or Enter to skip)")
            if not lang_selection.strip():
                break  # Skip
            nums = [s.strip() for s in lang_selection.split(',')]
            if len(nums) != len(set(nums)):
                print_error("Duplicate selections are not allowed.")
                continue
            if all(n in valid_lang_nums for n in nums):
                break
            print_error(f"Please enter numbers between 1 and {other_num} (comma-separated).")
        progress['lang_selection'] = lang_selection
        _save_progress(prog_file, progress)
    else:
        lang_selection = progress['lang_selection']
        info(f"  [resumed] Languages: {lang_selection or '(skipped)'}")
    
    lang_nums = [s.strip() for s in lang_selection.split(',')]
    languages = []
    for num in lang_nums:
        try:
            idx = int(num) - 1
            if 0 <= idx < len(available_langs):
                languages.append(f"- {available_langs[idx][1]}")
            elif int(num) == other_num:
                other_lang = _resume_or_ask(progress, prog_file, 'other_lang',
                                            'Other language', read_input, "Enter language name")
                if other_lang:
                    languages.append(f"- {other_lang}")
        except ValueError:
            pass
    
    languages_str = '\n'.join(languages) if languages else "- (None specified)"
    
    available_strats = get_available_strategies()
    max_strat = len(available_strats)
    # Default to 'interview' strategy if available, otherwise first
    default_strat_num = "1"
    for i, (stem, _) in enumerate(available_strats, 1):
        if stem.lower() == "interview":
            default_strat_num = str(i)
            break
    if 'strat_selection' not in progress:
        if max_strat == 0:
            warn("No strategy files found in strategies/ — defaulting to Interview.")
            strat_selection = "1"
        else:
            print()
            print_section("Development Strategy")
            info("Select your default development strategy:")
            for i, (stem, display) in enumerate(available_strats, 1):
                desc = _STRATEGY_DESCRIPTIONS.get(stem, '')
                marker = " ★ RECOMMENDED" if str(i) == default_strat_num else ""
                print(f"  {i}. {display}{marker}")
                if desc:
                    print(f"     {desc}")
            print()
            info("💡 Strategies can be chained — after one completes, you'll be asked if you want to run another.")
            while True:
                strat_selection = read_input("Selection", default_strat_num)
                if not strat_selection.strip():
                    strat_selection = default_strat_num
                    break
                try:
                    num = int(strat_selection.strip())
                    if 1 <= num <= max_strat:
                        break
                except ValueError:
                    pass
                print_error(f"Please enter a number between 1 and {max_strat}.")
        progress['strat_selection'] = strat_selection
        _save_progress(prog_file, progress)
    else:
        strat_selection = progress['strat_selection']
        info(f"  [resumed] Strategy: {strat_selection}")
    
    try:
        strat_idx = int(strat_selection.strip()) - 1
        if 0 <= strat_idx < len(available_strats):
            selected_strategy = available_strats[strat_idx]
        else:
            selected_strategy = available_strats[0] if available_strats else ("interview", "Interview")
    except ValueError:
        selected_strategy = available_strats[0] if available_strats else ("interview", "Interview")
    strategy_stem, strategy_display = selected_strategy
    
    showed_custom_rules_header = 'has_custom_rules' not in progress
    if 'has_custom_rules' not in progress:
        print()
        print_section("Custom Rules")
        info("Add rules the AI must always follow (optional). Enter one rule per line, empty line to finish.")
        has_rules = read_yn("Do you have custom rules to add?")
        progress['has_custom_rules'] = has_rules
        _save_progress(prog_file, progress)
    else:
        has_rules = progress['has_custom_rules']

    if 'custom_rules' not in progress:
        if has_rules:
            if not showed_custom_rules_header:
                print()
                print_section("Custom Rules")
                info("Continuing rule collection (interrupted mid-loop). Empty line to finish.")
                print()
            rules_list = list(progress.get('custom_rules_wip', []))
            if rules_list:
                info(f"  [resumed] {len(rules_list)} rule(s) already collected:")
                for r in rules_list:
                    info(f"    {r}")
            while True:
                rule = read_input("  Rule (or Enter to finish)")
                if not rule.strip():
                    break
                rules_list.append(f"- {rule.strip().lstrip('- ').strip()}")
                progress['custom_rules_wip'] = rules_list
                _save_progress(prog_file, progress)
            custom_rules = '\n'.join(rules_list) if rules_list else ""
        else:
            custom_rules = ""
        progress['custom_rules'] = custom_rules
        progress.pop('custom_rules_wip', None)
        _save_progress(prog_file, progress)
    else:
        custom_rules = progress['custom_rules']
        display = custom_rules.replace('\n', '; ')
        info(f"  [resumed] Custom rules: {display[:60] + '...' if len(custom_rules) > 60 else display or '(none)'}")
    
    if any(k not in progress for k in ('use_soul', 'use_morals', 'use_code_field')):
        print()
        print_section("Meta Guidelines")
        info("Deft ships three meta-guidelines that shape how the AI behaves. All are included")
        info("by default — press Enter to keep each, or n to drop it.")
        print()
        info("SOUL.md — Results-first agent persona (inspired by Winston Wolf).")
        info("  Enforces assess-before-acting, finish-what-you-start, right-tool-for-the-job,")
        info("  and play-the-long-game. Keeps the AI decisive and concise rather than narrating")
        info("  every step. Includes a named persona ('Vinston') — drop if you prefer to define")
        info("  your own agent personality.")
        print()
        info("morals.md — Epistemic honesty rules.")
        info("  No presenting speculation as fact, label unverified claims, self-correct when")
        info("  wrong. Foundational trust rules for any AI agent. Strongly recommended.")
        print()
        info("code-field.md — Pre-code assumption protocol.")
        info("  Requires stating assumptions, naming failure modes, and writing only code the AI")
        info("  can defend — before writing a single line. Fights the 'it compiles, ship it'")
        info("  instinct. Based on the NeoVertex1 context-field framework.")
        print()
    use_soul = _resume_or_ask(progress, prog_file, 'use_soul', 'SOUL.md',
                               read_yn, "Include meta/SOUL.md? (Results-first persona)", default=True)
    use_morals = _resume_or_ask(progress, prog_file, 'use_morals', 'morals.md',
                                 read_yn, "Include meta/morals.md? (Epistemic honesty rules)", default=True)
    use_code_field = _resume_or_ask(progress, prog_file, 'use_code_field', 'code-field.md',
                                     read_yn, "Include meta/code-field.md? (Pre-code assumption protocol)", default=True)
    
    # Build experimental rules section
    experimental_rules = []
    if use_soul:
        experimental_rules.append("- ! Use meta/SOUL.md for strategic context and purpose-driven guidance")
    if use_morals:
        experimental_rules.append("- ! Use meta/morals.md for ethical AI development principles")
    if use_code_field:
        experimental_rules.append("- ~ Use meta/code-field.md for advanced architecture patterns")
    
    experimental_section = ""
    if experimental_rules:
        experimental_section = "\n## Experimental Rules\n\n" + "\n".join(experimental_rules)
    
    # Build coverage override line (only if non-default)
    coverage_line = f"\n**Coverage**: ! ≥{coverage}% test coverage" if coverage != "85" else ""
    
    # Build strategy line (omit link when no strategy files exist)
    if available_strats:
        strategy_line = f"**Default Strategy**: [{strategy_display}](../strategies/{strategy_stem}.md)"
    else:
        strategy_line = f"**Default Strategy**: {strategy_display}"
    
    # Generate user.md
    user_content = f"""# User Preferences

Legend (from RFC2119): !=MUST, ~=SHOULD, ≉=SHOULD NOT, ⊗=MUST NOT, ?=MAY.

## Personal (always wins)

Settings in this section have HIGHEST precedence — override all other deft rules,
including PROJECT.md.

**Name**: Address the user as: **{user_name}**

**Custom Rules**:
{custom_rules if custom_rules else "No custom rules defined yet."}

## Defaults (fallback)

Settings in this section are fallback defaults. PROJECT.md overrides these
for project-scoped settings (strategy, coverage, languages).

**Primary Languages**:
{languages_str}

{strategy_line}
{coverage_line}
{experimental_section}

---

**Note**: You can edit this file anytime to update your preferences.
**See**: [../main.md](../main.md) for framework defaults.
"""
    
    _atomic_write(user_file, user_content)
    _clear_progress(prog_file)
    
    success(f"Created user.md at {user_file}")
    print()
    info("user.md defines your personal preferences and default standards.")
    print()
    
    # Always offer to configure project settings
    print()
    print_section("Next Steps")
    if read_yn("Would you like to run 'run project' now?", default=True):
        print()
        return cmd_project([])
    else:
        print()
        info("You can run 'run project' later to configure your project")
        return 0

def cmd_project(args: List[str]):
    """Project command - configure PROJECT-DEFINITION.vbrief.json"""
    # USER.md gate (#163): mirror the agentic-path gate from
    # skills/deft-directive-build/SKILL.md. Refuse to do work if the user
    # has not yet bootstrapped their preferences -- the message names the
    # resolved path (platform-aware) and redirects to `run bootstrap`.
    gate_exit = _check_user_md_gate()
    if gate_exit is not None:
        return gate_exit
    print_header(f"Deft CLI v{VERSION} - Project Configuration")
    print()
    info("This command creates PROJECT-DEFINITION.vbrief.json, which defines YOUR project:")
    info("  • Tech stack and programming language (narratives)")
    info("  • Project type (CLI, API, Web App, Library, etc.)")
    info("  • Quality standards (test coverage thresholds)")
    info("  • Workflow commands (task check, task test, etc.)")
    print()
    info("This vBRIEF file tells AI assistants how to build and maintain YOUR project.")
    info("It works alongside the general Deft guidelines in ./deft/")
    print()
    
    defaults = get_default_paths()
    
    # Resume support (issue #8)
    prog_file = _progress_path(resolve_path(defaults['project']))
    progress = {}
    if prog_file.exists():
        saved = _load_progress(prog_file)
        if saved:
            print_section("Previous Session Found")
            for k, v in saved.items():
                if not k.startswith('_'):
                    info(f"  {k}: {v}")
            print()
            if read_yn("Resume where you left off?", default=True):
                progress = saved
            else:
                _clear_progress(prog_file)
    
    # Check if we're in a project directory
    if not Path("./deft").is_dir():
        warn("No ./deft directory found. Run 'run install' first or specify a project directory.")
        if read_yn("Install deft in current directory?"):
            return cmd_install(["."])
        else:
            return 1
    
    if 'output_path' not in progress:
        print_section("Output Location")
    project_path_str = _resume_or_ask(progress, prog_file, 'output_path', 'Output',
                                       read_input, "Where to write PROJECT-DEFINITION.vbrief.json", defaults['project'])
    project_file = resolve_path(project_path_str)
    
    # Gather project information
    dir_default = Path.cwd().name
    project_name = _resume_or_ask(progress, prog_file, 'project_name', 'Project',
                                   read_input, "Project name", dir_default)
    
    type_map = {
        "1": "CLI",
        "2": "TUI",
        "3": "REST API",
        "4": "Web App",
        "5": "Library",
        "6": "Other"
    }
    
    valid_type_nums = set(type_map.keys())
    if 'type_selection' not in progress:
        print()
        info("Select project type (comma-separated if multiple):")
        print("  1. CLI (Command-line interface)")
        print("  2. TUI (Terminal UI)")
        print("  3. REST API")
        print("  4. Web App")
        print("  5. Library")
        print("  6. Other")
        while True:
            type_selection = read_input("Selection")
            if not type_selection.strip():
                print_error("Please enter at least one selection (1-6).")
                continue
            nums = [s.strip() for s in type_selection.split(',')]
            if len(nums) != len(set(nums)):
                print_error("Duplicate selections are not allowed.")
                continue
            if all(n in valid_type_nums for n in nums):
                break
            print_error("Please enter numbers between 1 and 6 (comma-separated).")
        progress['type_selection'] = type_selection
        _save_progress(prog_file, progress)
    else:
        type_selection = progress['type_selection']
        info(f"  [resumed] Type: {type_selection}")
    
    type_nums = [s.strip() for s in type_selection.split(',')]
    project_types = []
    custom_type = ""
    
    for num in type_nums:
        if num == "6":
            custom_type = _resume_or_ask(progress, prog_file, 'custom_type', 'Custom type',
                                          read_input, "Enter custom project type")
            project_types.append(custom_type)
        elif num in type_map:
            project_types.append(type_map[num])
    
    project_types_str = ", ".join(project_types)
    
    # Read USER.md defaults to avoid re-asking questions already answered
    # during bootstrap (fix for #7 — double prompting)
    user_defaults = _read_user_defaults(defaults)
    
    # Language selection — pre-fill from USER.md if available
    available_langs = get_available_languages()
    other_num = len(available_langs) + 1
    valid_lang_nums = set(str(i) for i in range(1, other_num + 1))
    if 'lang_selection' not in progress:
        print()
        if user_defaults.get('languages'):
            user_lang_names = user_defaults['languages']
            user_lang_display = ', '.join(user_lang_names)
            info(f"Languages from USER.md: {user_lang_display}")
            info("Select primary programming language(s) (comma-separated):")
            for i, (stem, display) in enumerate(available_langs, 1):
                print(f"  {i}. {display}")
            print(f"  {other_num}. Other")
            while True:
                lang_selection = read_input(
                    f"Selection, or Enter to keep [{user_lang_display}]", ""
                )
                if not lang_selection.strip():
                    break  # Accept USER.md defaults
                nums = [s.strip() for s in lang_selection.split(',')]
                if len(nums) != len(set(nums)):
                    print_error("Duplicate selections are not allowed.")
                    continue
                if all(n in valid_lang_nums for n in nums):
                    break
                print_error(f"Please enter numbers between 1 and {other_num} (comma-separated).")
        else:
            info("Select primary programming language(s) (comma-separated):")
            for i, (stem, display) in enumerate(available_langs, 1):
                print(f"  {i}. {display}")
            print(f"  {other_num}. Other")
            while True:
                lang_selection = read_input("Selection (e.g., 1,3)")
                if not lang_selection.strip():
                    break  # Skip (falls through to Python default)
                nums = [s.strip() for s in lang_selection.split(',')]
                if len(nums) != len(set(nums)):
                    print_error("Duplicate selections are not allowed.")
                    continue
                if all(n in valid_lang_nums for n in nums):
                    break
                print_error(f"Please enter numbers between 1 and {other_num} (comma-separated).")
        progress['lang_selection'] = lang_selection
        progress['_had_user_lang_defaults'] = bool(user_defaults.get('languages'))
        _save_progress(prog_file, progress)
    else:
        lang_selection = progress['lang_selection']
        info(f"  [resumed] Languages: {lang_selection or '(USER.md defaults)'}")
    
    # Parse language selection
    has_user_lang_defaults = user_defaults.get('languages') or progress.get('_had_user_lang_defaults')
    if not lang_selection.strip() and has_user_lang_defaults:
        # Accept USER.md defaults
        user_lang_names = user_defaults.get('languages', [])
        selected_langs = []
        for lang_name in user_lang_names:
            matched = False
            for stem, display in available_langs:
                if display.lower() == lang_name.lower():
                    selected_langs.append((stem, display))
                    matched = True
                    break
            if not matched:
                selected_langs.append((lang_name.lower(), lang_name))
        if not selected_langs:
            selected_langs = [("python", "Python")]
    else:
        lang_nums = [s.strip() for s in lang_selection.split(',')]
        selected_langs = []
        for num in lang_nums:
            try:
                idx = int(num) - 1
                if 0 <= idx < len(available_langs):
                    selected_langs.append(available_langs[idx])
                elif int(num) == other_num:
                    other_lang = _resume_or_ask(progress, prog_file, 'other_lang',
                                                'Other language', read_input, "Enter language name")
                    if other_lang:
                        selected_langs.append((other_lang.lower(), other_lang))
            except ValueError:
                pass
        if not selected_langs:
            selected_langs = [("python", "Python")]
    
    primary_lang = selected_langs[0][1]
    primary_stem = selected_langs[0][0]
    
    # Coverage — pre-fill from USER.md if available
    if 'coverage' not in progress:
        print()
        user_coverage = user_defaults.get('coverage', '85') if user_defaults else None
        while True:
            if user_coverage:
                proj_coverage = read_input(
                    f"Coverage threshold (from USER.md: {user_coverage}%)", user_coverage
                )
            else:
                proj_coverage = read_input("Coverage threshold (default: 85%)", "85")
            if not proj_coverage.strip():
                proj_coverage = user_coverage or "85"
                break
            try:
                val = int(proj_coverage.strip())
                if 1 <= val <= 100:
                    break
            except ValueError:
                pass
            print_error("Please enter a number between 1 and 100.")
        progress['coverage'] = proj_coverage
        _save_progress(prog_file, progress)
    else:
        proj_coverage = progress['coverage']
        info(f"  [resumed] Coverage: {proj_coverage}")
    
    tech_stack = _resume_or_ask(progress, prog_file, 'tech_stack', 'Tech stack',
                                 read_input, "Tech stack details (e.g., 'Flask + SQLAlchemy' or 'React + Next.js')")
    
    # Strategy — pre-fill from USER.md if available
    available_strats = get_available_strategies()
    max_strat = len(available_strats)
    # Compute recommended marker (same logic as cmd_bootstrap)
    default_strat_num = "1"
    for i, (stem, _) in enumerate(available_strats, 1):
        if stem.lower() == "interview":
            default_strat_num = str(i)
            break
    if 'strat_selection' not in progress:
        if max_strat == 0:
            warn("No strategy files found in strategies/ — defaulting to Interview.")
            strat_selection = "1"
        else:
            print()
            print_section("Development Strategy")
            if user_defaults.get('strategy'):
                user_strat_stem = user_defaults['strategy']
                user_strat_display = user_defaults.get('strategy_display', user_strat_stem.title())
                info(f"Default strategy from USER.md: {user_strat_display}")
                info("Does this project need a different strategy?")
                user_pref_strat_num = next(
                    (str(i) for i, (stem, _) in enumerate(available_strats, 1)
                     if stem.lower() == user_strat_stem.lower()),
                    default_strat_num,
                )
                for i, (stem, display) in enumerate(available_strats, 1):
                    desc = _STRATEGY_DESCRIPTIONS.get(stem, '')
                    marker = " ★ your default" if str(i) == user_pref_strat_num else ""
                    print(f"  {i}. {display}{marker}")
                    if desc:
                        print(f"     {desc}")
                print()
                info("💡 Strategies can be chained — after one completes, you'll be asked if you want to run another.")
                while True:
                    strat_selection = read_input(
                        f"Selection, or Enter to keep [{user_strat_display}]", ""
                    )
                    if not strat_selection.strip():
                        break  # Accept USER.md default
                    try:
                        num = int(strat_selection.strip())
                        if 1 <= num <= max_strat:
                            break
                    except ValueError:
                        pass
                    print_error(f"Please enter a number between 1 and {max_strat}.")
            else:
                info("Select development strategy for this project:")
                for i, (stem, display) in enumerate(available_strats, 1):
                    desc = _STRATEGY_DESCRIPTIONS.get(stem, '')
                    marker = " ★ RECOMMENDED" if str(i) == default_strat_num else ""
                    print(f"  {i}. {display}{marker}")
                    if desc:
                        print(f"     {desc}")
                print()
                info("💡 Strategies can be chained — after one completes, you'll be asked if you want to run another.")
                while True:
                    strat_selection = read_input("Selection", "1")
                    if not strat_selection.strip():
                        strat_selection = "1"
                        break
                    try:
                        num = int(strat_selection.strip())
                        if 1 <= num <= max_strat:
                            break
                    except ValueError:
                        pass
                    print_error(f"Please enter a number between 1 and {max_strat}.")
        progress['strat_selection'] = strat_selection
        progress['_had_user_strat_default'] = bool(user_defaults.get('strategy'))
        _save_progress(prog_file, progress)
    else:
        strat_selection = progress['strat_selection']
        info(f"  [resumed] Strategy: {strat_selection or '(USER.md default)'}")
    
    # Parse strategy selection
    has_user_strat_default = user_defaults.get('strategy') or progress.get('_had_user_strat_default')
    if not strat_selection.strip() and has_user_strat_default:
        user_strat_stem = user_defaults.get('strategy', 'interview')
        user_strat_display = user_defaults.get('strategy_display', user_strat_stem.title())
        selected_strategy = (user_strat_stem, user_strat_display)
    else:
        try:
            strat_idx = int(strat_selection.strip()) - 1
            if 0 <= strat_idx < len(available_strats):
                selected_strategy = available_strats[strat_idx]
            else:
                selected_strategy = available_strats[0] if available_strats else ("interview", "Interview")
        except ValueError:
            selected_strategy = available_strats[0] if available_strats else ("interview", "Interview")
    strategy_stem, strategy_display = selected_strategy
    
    # Branching preference
    if 'branching' not in progress:
        print()
        print_section("Branching Workflow")
        info("Choose your branching strategy:")
        print("  1. Branch-based ★ RECOMMENDED — create a feature branch for every change")
        print("  2. Trunk-based — commit directly to master/main (common for solo projects)")
        while True:
            branch_selection = read_input("Selection", "1")
            if branch_selection.strip() in ("1", "2"):
                break
            print_error("Please enter 1 or 2.")
        progress['branching'] = branch_selection.strip()
        _save_progress(prog_file, progress)
    else:
        branch_selection = progress['branching']
        info(f"  [resumed] Branching: {branch_selection}")
    
    allow_direct_commits = (branch_selection.strip() == "2")
    
    # Generate project.md
    tech_stack_str = f" - {tech_stack}" if tech_stack else ""
    today = datetime.now().strftime("%Y-%m-%d")
    
    # Build language links and display string
    lang_links = " | ".join([f"[../languages/{s}.md](../languages/{s}.md)" for s, _ in selected_langs])
    lang_names = ", ".join([d for _, d in selected_langs])
    
    # Build vBRIEF PROJECT-DEFINITION structure
    # Narratives hold project identity per RFC D3
    narratives = {
        "Overview": f"{project_name} -- {project_types_str} using {lang_names}",
        "TechStack": f"{project_types_str} using {lang_names}" + (f" - {tech_stack}" if tech_stack else ""),
        "Languages": lang_names,
        "Strategy": f"{strategy_display} (strategies/{strategy_stem}.md)",
        "Coverage": f">={proj_coverage}%",
    }
    if allow_direct_commits:
        narratives["Branching"] = "Allow direct commits to master: true"

    project_definition = {
        "vBRIEFInfo": {
            "version": "0.5",
            "description": f"PROJECT-DEFINITION for {project_name}. Generated by run v{VERSION}.",
            "updated": today,
        },
        "plan": {
            "title": f"{project_name} Project Definition",
            "status": "running",
            "narratives": narratives,
            "items": [],
            "metadata": {
                "generator": f"run v{VERSION}",
                "generatedAt": today,
            },
        },
    }

    project_content = json.dumps(project_definition, indent=2, ensure_ascii=False)
    _atomic_write(project_file, project_content + "\n")

    # Scaffold vBRIEF lifecycle subdirectories (#404).
    # The skill-driven greenfield path creates these; the CLI path must match
    # so `task vbrief:validate` and `task scope:*` work immediately after
    # `run project`.
    vbrief_root = project_file.parent
    for _lifecycle_folder in LIFECYCLE_FOLDERS:
        (vbrief_root / _lifecycle_folder).mkdir(parents=True, exist_ok=True)

    # Record framework version marker for the upgrade gate (#410).
    _write_version_marker(vbrief_root)

    _clear_progress(prog_file)
    
    success(f"Created PROJECT-DEFINITION.vbrief.json at {project_file}")
    print()
    info("PROJECT-DEFINITION.vbrief.json defines your project's identity, tech stack, and quality standards.")
    info("Scope vBRIEFs in vbrief/proposed/ reference this file as the project gestalt.")
    print()
    
    # Prompt to run spec generation
    print()
    print_section("Next Steps")
    info("Generate a scope vBRIEF via AI interview")
    info("The 'spec' command creates a scope vBRIEF in vbrief/proposed/")
    info("for your AI assistant to work from.")
    print()
    if read_yn("Would you like to run 'run spec' now?", default=True):
        print()
        return cmd_spec([])
    else:
        print()
        info("You can run 'run spec' later to generate your specification.")
        return 0

def _read_user_defaults(defaults: dict) -> dict:
    """Read fallback defaults from USER.md if present.
    
    Parses Primary Languages, Default Strategy, and Coverage from USER.md.
    Returns a dict with keys 'languages', 'strategy', 'coverage' where found.
    Returns empty dict if USER.md does not exist.
    """
    user_path_str = defaults.get('user', '')
    if not user_path_str:
        return {}
    user_file = resolve_path(user_path_str)
    if not user_file.exists():
        return {}
    
    result = {}
    try:
        content = user_file.read_text(encoding='utf-8')
        lines = content.split('\n')
        
        # Parse languages: lines starting with "- " after "**Primary Languages**:"
        in_languages = False
        languages = []
        for line in lines:
            stripped = line.strip()
            if stripped.startswith('**Primary Languages**:'):
                in_languages = True
                continue
            if in_languages:
                if stripped.startswith('- ') and stripped != '- (None specified)':
                    languages.append(stripped[2:].strip())
                elif stripped and not stripped.startswith('- '):
                    in_languages = False
        if languages:
            result['languages'] = languages
        
        # Parse strategy: [Name](../strategies/stem.md)
        for line in lines:
            stripped = line.strip()
            if stripped.startswith('**Default Strategy**:') and 'strategies/' in stripped:
                start = stripped.index('strategies/') + len('strategies/')
                rest = stripped[start:]
                if '.md' in rest:
                    stem = rest[:rest.index('.md')]
                    if stem:
                        result['strategy'] = stem
                        # Also extract display name from [Name](...)
                        try:
                            bracket_start = stripped.index('[') + 1
                            bracket_end = stripped.index(']')
                            result['strategy_display'] = stripped[bracket_start:bracket_end]
                        except ValueError:
                            pass
                break
        
        # Parse coverage: **Coverage**: ! ≥N% 
        for line in lines:
            stripped = line.strip()
            if stripped.startswith('**Coverage**:') and '≥' in stripped and '%' in stripped:
                ge_pos = stripped.index('≥') + 1
                pct_pos = stripped.index('%')
                coverage_val = stripped[ge_pos:pct_pos].strip()
                if coverage_val.isdigit():
                    result['coverage'] = coverage_val
                break
    except Exception:
        pass
    
    return result


def _read_project_process(defaults: dict) -> Optional[str]:
    """Read Process value from PROJECT-DEFINITION.vbrief.json or legacy PROJECT.md.
    
    Returns 'Light', 'Full', or None.
    """
    project_default = resolve_path(defaults['project'])
    project_legacy = _legacy_project_path()
    project_file = project_default if project_default.exists() else project_legacy
    if not project_file.exists():
        return None
    try:
        content = project_file.read_text(encoding='utf-8')
        # Try vBRIEF JSON format first
        if project_file.name.endswith('.vbrief.json'):
            data = json.loads(content)
            process_val = data.get('plan', {}).get('narratives', {}).get('Process', '')
            if process_val.lower() in ('light', 'full'):
                return process_val.capitalize()
            return None
        # Legacy PROJECT.md format
        for line in content.split('\n'):
            stripped = line.strip()
            if stripped.startswith('**Process**:'):
                value = stripped.split(':', 1)[1].strip().rstrip('*').strip()
                if value.lower() in ('light', 'full'):
                    return value.capitalize()
    except Exception:
        pass
    return None

def _read_project_strategy(defaults: dict) -> Optional[str]:
    """Read strategy file stem from PROJECT-DEFINITION.vbrief.json or legacy PROJECT.md.
    
    For vBRIEF format, reads plan.narratives.Strategy which contains:
        "Interview (strategies/interview.md)"
    
    For legacy PROJECT.md, parses the ## Strategy section for a link like:
        Use [Name](path/strategies/stem.md) for this project.
    
    Returns strategy stem (e.g. 'interview', 'discuss') or None.
    """
    project_default = resolve_path(defaults['project'])
    project_legacy = _legacy_project_path()
    project_file = project_default if project_default.exists() else project_legacy
    if not project_file.exists():
        return None
    try:
        content = project_file.read_text(encoding='utf-8')
        # Try vBRIEF JSON format first
        if project_file.name.endswith('.vbrief.json'):
            data = json.loads(content)
            strategy_val = data.get('plan', {}).get('narratives', {}).get('Strategy', '')
            if 'strategies/' in strategy_val and '.md' in strategy_val:
                start = strategy_val.index('strategies/') + len('strategies/')
                rest = strategy_val[start:]
                stem = rest[:rest.index('.md')]
                if stem:
                    return stem
            return None
        # Legacy PROJECT.md format
        for line in content.split('\n'):
            stripped = line.strip()
            if stripped.startswith('Use [') and 'strategies/' in stripped:
                start = stripped.index('strategies/') + len('strategies/')
                rest = stripped[start:]
                if '.md' in rest:
                    stem = rest[:rest.index('.md')]
                    if stem:
                        return stem
    except Exception:
        pass
    return None

def _slugify(text: str) -> str:
    """Convert text to a URL-friendly slug for vBRIEF filenames.
    
    Strips non-alphanumeric characters, lowercases, and joins with hyphens.
    """
    text = text.lower().strip()
    text = re.sub(r'[^a-z0-9\s_-]', '', text)
    text = re.sub(r'[\s_]+', '-', text)
    text = re.sub(r'-+', '-', text)
    return text[:60].strip('-')  # Cap slug length, remove any trailing hyphen

def cmd_spec(args: List[str]):
    """Spec command - generate scope vBRIEF via interview"""
    # USER.md gate (#163): mirror the agentic-path gate from
    # skills/deft-directive-build/SKILL.md. Refuse to do work if the user
    # has not yet bootstrapped their preferences -- the message names the
    # resolved path (platform-aware) and redirects to `run bootstrap`.
    gate_exit = _check_user_md_gate()
    if gate_exit is not None:
        return gate_exit
    print_header(f"Deft CLI v{VERSION} - Scope vBRIEF Generator")
    print()
    
    defaults = get_default_paths()
    strategy = _read_project_strategy(defaults) or 'interview'
    
    # Resume support (issue #8)
    prog_file = _progress_path(resolve_path(defaults['vbrief_proposed']))
    progress = {}
    if prog_file.exists():
        saved = _load_progress(prog_file)
        if saved:
            print_section("Previous Session Found")
            for k, v in saved.items():
                if not k.startswith('_'):
                    info(f"  {k}: {v}")
            print()
            if read_yn("Resume where you left off?", default=True):
                progress = saved
            else:
                _clear_progress(prog_file)
    
    info("This command creates a scope vBRIEF in vbrief/proposed/ for your AI assistant.")
    if strategy != 'interview':
        info(f"Strategy: {strategy} (from PROJECT-DEFINITION.vbrief.json)")
        info(f"Your AI will follow strategies/{strategy}.md, which chains into")
        info("the sizing gate for scope generation:")
    else:
        info("It follows strategies/interview.md with a sizing gate:")
    info("  \u2022 Light: \u2192 scope vBRIEF in vbrief/proposed/ (embedded requirements)")
    info("  \u2022 Full:  \u2192 scope vBRIEF with rich narratives (approval gate)")
    print()
    info("After creating the file, you'll:")
    info("  1. Give it to your AI assistant")
    info(f"  2. The AI reads strategies/{strategy}.md and follows its workflow")
    info("  3. The AI refines the scope vBRIEF with implementation details")
    info("  4. The AI can then implement the scope")
    print()
    
    # Try to read project name from PROJECT-DEFINITION.vbrief.json (check new default, then legacy)
    project_default = resolve_path(defaults['project'])
    project_legacy = _legacy_project_path()
    project_file = project_default if project_default.exists() else project_legacy
    if 'spec_name' not in progress:
        spec_name = ""
        if project_file.exists():
            try:
                content = project_file.read_text(encoding='utf-8')
                if project_file.name.endswith('.vbrief.json'):
                    data = json.loads(content)
                    title = data.get('plan', {}).get('title', '')
                    if title and 'Project Definition' in title:
                        spec_name = title.replace(' Project Definition', '').strip()
                    elif title:
                        spec_name = title
                else:
                    # Legacy PROJECT.md format
                    for line in content.split('\n'):
                        if line.startswith('# ') and 'Project Guidelines' in line:
                            spec_name = line.replace('# ', '').replace(' Project Guidelines', '').strip()
                            break
            except (OSError, UnicodeDecodeError, json.JSONDecodeError):
                pass  # Best-effort: fall back to manual name entry
        
        if spec_name:
            info(f"Project name from PROJECT-DEFINITION: {spec_name}")
            if not read_yn("Use this name?", default=True):
                spec_name = read_input("Project name")
        else:
            spec_name = read_input("Project name")
        progress['spec_name'] = spec_name
        _save_progress(prog_file, progress)
    else:
        spec_name = progress['spec_name']
        info(f"  [resumed] Project: {spec_name}")
    
    spec_desc = _resume_or_ask(progress, prog_file, 'spec_desc', 'Description',
                                read_input, "Brief description (1-2 sentences)")
    
    if 'features' not in progress:
        print()
        info("Enter project features (one per line, empty line to finish):")
        features = []
        while True:
            feature = read_input("  Feature")
            if not feature:
                break
            features.append(feature)
        progress['features'] = features
        _save_progress(prog_file, progress)
    else:
        features = progress['features']
        info(f"  [resumed] Features: {len(features)} feature(s)")
    
    # Sizing gate
    if 'sizing' not in progress:
        print()
        print_section("Scope Complexity")
        
        process_override = _read_project_process(defaults)
        if process_override:
            info(f"PROJECT-DEFINITION declares Process: {process_override} -- using that.")
            sizing = process_override
        else:
            recommended = "Light" if len(features) <= 5 else "Full"
            info(f"Based on {len(features)} feature(s), recommended: {recommended}")
            info("  1. Light -- scope vBRIEF with embedded requirements")
            info("  2. Full  -- scope vBRIEF with rich narratives (approval gate)")
            sizing_choice = read_input("Selection", "1" if recommended == "Light" else "2")
            sizing = "Light" if sizing_choice.strip() == "1" else "Full"
        progress['sizing'] = sizing
        _save_progress(prog_file, progress)
    else:
        sizing = progress['sizing']
        info(f"  [resumed] Path: {sizing}")
    
    # Determine output location -- always vbrief/proposed/
    proposed_dir = resolve_path(defaults['vbrief_proposed'])
    today = datetime.now().strftime("%Y-%m-%d")
    slug = _slugify(spec_name)
    output_filename = f"{today}-{slug}.vbrief.json"
    output_file = proposed_dir / output_filename
    
    if not progress.get('_write_ready'):
        if output_file.exists() and "--force" not in args:
            warn(f"{output_file} already exists. Use --force to overwrite.")
            return 1
    progress['_write_ready'] = True
    _save_progress(prog_file, progress)
    
    # Build scope vBRIEF structure
    items = []
    for i, feature in enumerate(features, 1):
        items.append({
            "id": f"F{i}",
            "title": feature,
            "status": "proposed",
        })

    # Build strategy-specific narratives
    narratives = {
        "Overview": spec_desc,
        "Strategy": f"{strategy} ({sizing} path)",
    }
    if sizing == "Full":
        narratives["ProblemStatement"] = ""
        narratives["Goals"] = ""
        narratives["UserStories"] = ""
        narratives["Requirements"] = ""
        narratives["SuccessMetrics"] = ""

    scope_vbrief = {
        "vBRIEFInfo": {
            "version": "0.5",
            "description": f"Scope vBRIEF for {spec_name}. Generated by run v{VERSION}.",
            "updated": today,
        },
        "plan": {
            "title": spec_name,
            "status": "proposed",
            "narratives": narratives,
            "items": items,
            "metadata": {
                "generator": f"run v{VERSION}",
                "generatedAt": today,
                "strategy": strategy,
                "sizing": sizing,
            },
        },
    }

    output_content = json.dumps(scope_vbrief, indent=2, ensure_ascii=False)
    _atomic_write(output_file, output_content + "\n")
    _clear_progress(prog_file)
    
    success(f"Created scope vBRIEF at {output_file}")
    info(f"Path: {sizing}")
    info("Next steps:")
    info(f"  1. Open your AI assistant (Claude, Warp.dev, etc.)")
    info(f"  2. Ask your AI to read {output_file}")
    info(f"  3. The AI reads strategies/{strategy}.md and follows its workflow")
    info("  4. The AI refines the scope vBRIEF with implementation details")
    info("  5. Promote the vBRIEF through lifecycle folders as work progresses")
    return 0

def cmd_install(args: List[str]):
    """Install command - install deft framework in a project"""
    target_dir = Path(args[0]) if args else Path(".")
    
    print_header(f"Deft CLI v{VERSION} - Installation")
    print()
    info("This command installs the Deft framework in your project directory.")
    info("It will create:")
    info("  • ./deft/        - Framework files (guidelines, templates, references)")
    info("  • ./secrets/        - Directory for API keys and credentials (.gitignored)")
    info("  • ./docs/           - Project documentation")
    info("  • Taskfile.yml      - Task automation config (if not present)")
    info("  • .gitignore        - Ensures secrets aren't committed (if not present)")
    print()
    info(f"Target directory: {target_dir.absolute()}")
    print()
    
    if not target_dir.exists():
        error(f"Directory does not exist: {target_dir}")
        return 1
    
    # Change to target directory
    original_dir = Path.cwd()
    os.chdir(target_dir)
    
    try:
        deft_dir = Path("./deft")
        
        # Check if deft already exists
        already_installed = deft_dir.exists()
        if already_installed:
            warn("Deft already installed in this directory.")
            if not read_yn("Reinstall?"):
                # Still offer to run project even if not reinstalling
                print()
                print_section("Next Steps")
                if read_yn("Would you like to run 'run project' now?"):
                    print()
                    return cmd_project([])
                else:
                    return 0
        
        # Copy deft framework
        info("Copying deft framework...")
        script_dir = get_script_dir()
        
        if deft_dir.exists():
            shutil.rmtree(deft_dir)
        
        shutil.copytree(script_dir, deft_dir)
        
        # Create project-specific files
        Path("secrets").mkdir(exist_ok=True)
        Path("docs").mkdir(exist_ok=True)
        Path("secrets/.gitkeep").touch()
        
        # Create .gitignore for secrets
        gitignore = Path(".gitignore")
        if not gitignore.exists():
            gitignore.write_text("secrets/*\n!secrets/.gitkeep\n!secrets/*.example\n", encoding='utf-8')
        
        # Create basic Taskfile if it doesn't exist
        taskfile = Path("Taskfile.yml")
        if not taskfile.exists():
            taskfile_content = """version: '3'

tasks:
  default:
    desc: List all tasks
    cmds:
      - task --list
    silent: true

  check:
    desc: Run all pre-commit checks
    cmds:
      - echo "Add your check commands here"
      - task fmt
      - task lint
      - task test

  fmt:
    desc: Format code
    cmds:
      - echo "Add your format command here"

  lint:
    desc: Lint code
    cmds:
      - echo "Add your lint command here"

  test:
    desc: Run tests
    cmds:
      - echo "Add your test command here"

  test:coverage:
    desc: Run tests with coverage
    cmds:
      - echo "Add your coverage command here"
"""
            taskfile.write_text(taskfile_content, encoding='utf-8')
            success("Created Taskfile.yml")
        
        success("Deft installed successfully!")
        print()
        
        # Prompt to run project configuration
        print_section("Next Steps")
        if read_yn("Would you like to run 'run project' now?"):
            print()
            return cmd_project([])
        else:
            print()
            info("You can run these commands later:")
            info("  ./deft/run project     # Configure this project")
            info("  ./deft/run bootstrap   # Set up user preferences")
            return 0
    
    finally:
        os.chdir(original_dir)

def cmd_validate(args: List[str]):
    """Validate command - check deft configuration"""
    print_header(f"Deft CLI v{VERSION} - Validate")
    print()
    info("Validating Deft configuration...")
    print()
    
    script_dir = get_script_dir()
    errors = 0
    
    # Check for required files
    required_files = [
        "main.md",
        "core/user.md",
        "coding/coding.md",
        "REFERENCES.md"
    ]
    
    for file in required_files:
        filepath = script_dir / file
        if filepath.exists():
            success(f"Found: {file}")
        else:
            error(f"Missing: {file}")
            errors += 1
    
    # Check for at least one language file
    lang_dir = script_dir / "languages"
    if lang_dir.exists() and list(lang_dir.glob("*.md")):
        success("Language files present")
    else:
        error("No language files found in languages/")
        errors += 1
    
    # Check for broken links (simple check)
    info("Checking for common broken links...")
    # Note: Python implementation could be more sophisticated
    
    print()
    if errors == 0:
        success("Validation passed! Deft configuration is valid.")
        return 0
    else:
        error(f"Validation failed with {errors} error(s).")
        return 1

def cmd_doctor(args: List[str]):
    """Doctor command - check system dependencies"""
    print_header(f"Deft CLI v{VERSION} - Doctor")
    print()
    info("Checking system dependencies...")
    print()
    
    warnings = 0
    
    # Check for required tools
    def check_command(cmd: str, name: str, required: bool = False):
        nonlocal warnings
        if shutil.which(cmd):
            success(f"{name} is installed")
        else:
            if required:
                error(f"{name} not found - required")
            else:
                warn(f"{name} not found - install from https://taskfile.dev" if cmd == "task" 
                     else f"{name} not found")
                warnings += 1
    
    check_command("task", "task (Taskfile)")
    check_command("git", "git", required=True)
    check_command("python3", "python3")
    check_command("go", "go")
    check_command("node", "node")
    
    # Check directory structure
    print()
    info("Checking Deft structure...")
    
    script_dir = get_script_dir()
    expected_dirs = ["core", "languages", "interfaces", "tools", "swarm", "templates", "meta"]
    
    for dir_name in expected_dirs:
        dir_path = script_dir / dir_name
        if dir_path.is_dir():
            success(f"Directory: {dir_name}/")
        else:
            warn(f"Missing directory: {dir_name}/")
            warnings += 1
    
    print()
    if warnings == 0:
        success("System check passed!")
    else:
        warn(f"System check completed with {warnings} warning(s).")
    
    return 0

def cmd_update(args: List[str]):
    """Update command - update deft framework"""
    print_header(f"Deft CLI v{VERSION} - Update")
    print()
    info("Deft update functionality not yet implemented")
    warn("Manual update: Replace deft directory with latest version from repository")
    return 0

def cmd_reset(args: List[str]):
    """Reset command - reset configuration files to default/empty state"""
    print_header(f"Deft CLI v{VERSION} - Reset")
    print()
    info("This command resets deft configuration files to their default state.")
    info("You can choose which files to reset:")
    print()
    defaults = get_default_paths()
    user_default = resolve_path(defaults['user'])
    project_default = resolve_path(defaults['project'])
    prd_default = resolve_path(defaults['prd'])
    spec_default = resolve_path(defaults['specification'])
    
    info(f"  • USER.md           - Your personal preferences ({defaults['user']})")
    info(f"  • PROJECT.md        - Project configuration ({defaults['project']})")
    info(f"  • PRD.md            - Product requirements document ({defaults['prd']})")
    info(f"  • SPECIFICATION.md  - Generated specification ({defaults['specification']})")
    print()
    
    # Check what exists (new default locations and legacy locations)
    user_file = user_default if user_default.exists() else _legacy_user_path()
    project_file = project_default if project_default.exists() else _legacy_project_path()
    prd_file = prd_default
    spec_file = spec_default
    
    files_to_reset = []
    
    # Check each file and ask if user wants to reset it
    if "--all" in args:
        # Reset all without asking
        if user_file.exists():
            files_to_reset.append(("user.md", user_file, True))
        if project_file.exists():
            files_to_reset.append(("project.md", project_file, False))
        if prd_file.exists():
            files_to_reset.append(("PRD.md", prd_file, False))
        if spec_file.exists():
            files_to_reset.append(("SPECIFICATION.md", spec_file, False))
    else:
        # Ask for each file
        if user_file.exists():
            if read_yn("Reset user.md to default template?"):
                files_to_reset.append(("user.md", user_file, True))
        
        if project_file.exists():
            if read_yn("Delete project.md?"):
                files_to_reset.append(("project.md", project_file, False))
        
        if prd_file.exists():
            if read_yn("Delete PRD.md?"):
                files_to_reset.append(("PRD.md", prd_file, False))
        
        if spec_file.exists():
            if read_yn("Delete SPECIFICATION.md?"):
                files_to_reset.append(("SPECIFICATION.md", spec_file, False))
    
    if not files_to_reset:
        print()
        info("No files to reset.")
        return 0
    
    # Confirm
    print()
    warn("The following files will be reset/deleted:")
    for name, _, _ in files_to_reset:
        warn(f"  • {name}")
    print()
    
    if "--all" not in args and not read_yn("Are you sure you want to continue?"):
        info("Reset cancelled.")
        return 0
    
    # Perform reset
    print()
    for name, filepath, reset_to_default in files_to_reset:
        if reset_to_default:
            # Reset user.md to default template
            default_content = """# User Preferences

Legend (from RFC2119): !=MUST, ~=SHOULD, ≉=SHOULD NOT, ⊗=MUST NOT, ?=MAY.

## Personal (always wins)

Settings in this section have HIGHEST precedence — override all other deft rules,
including PROJECT.md.

**Name**: Address the user as: **(Your Name)**

**Custom Rules**:
No custom rules defined yet.

## Defaults (fallback)

Settings in this section are fallback defaults. PROJECT.md overrides these
for project-scoped settings (strategy, coverage, languages).

**Primary Languages**:
- (Add your languages here)

---

**Note**: You can edit this file anytime to update your preferences.
**See**: [../main.md](../main.md) for framework defaults.
"""
            filepath.write_text(default_content, encoding='utf-8')
            success(f"Reset {name} to default template")
        else:
            # Delete file
            filepath.unlink()
            success(f"Deleted {name}")
    
    print()
    success("Reset complete!")
    info("Run 'run bootstrap' or 'run project' to reconfigure.")
    return 0

